{
  "manifest_version": 3,
  "name": "Chrome 页面管理插件",
  "version": "1.0.0",
  "description": "一个简单高效的 Chrome 页面管理工具，支持分组、标签、一键打开等功能",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  }
}
