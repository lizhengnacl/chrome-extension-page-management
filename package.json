{
  "name": "chrome-extension-page-management",
  "version": "1.0.0",
  "description": "一个简单高效的 Chrome 页面管理工具，让您轻松组织和管理常用网页。",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./lib/output.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./lib/output.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "3"
  }
}
